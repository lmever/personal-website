---
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import Hero from '../features/hero/Hero.tsx';
import MicrosoftExperience from '../features/microsoft/MicrosoftExperience.tsx';
import DatawhaleStory from '../features/datawhale/DatawhaleStory.astro';
import Music from '../features/music/Music.astro';
import MusicDecor from '../features/hero/MusicDecor.tsx';
import site from '../data/site.json';
import resume from '../data/resume.json';
import FilmStrip from '../features/filmstrip/FilmStrip.astro';

const featuredProjects = resume.projects.map((project, index) => ({
  ...project,
  label: String(index + 1).padStart(2, '0'),
  tags: index === 0 ? ['RAG', 'LangGraph', 'Milvus'] : index === 1 ? ['Music AI', 'Agent', 'Audio'] : ['ANTLR', 'DSL', 'AST'],
  type: index === 0 ? 'Side Project' : index === 1 ? 'Creative System' : 'Engineering Study',
}));

const inspirationPreview = [
  { type: 'Books', title: 'Systems thinking', impact: 'Shaped how I turn scattered work into repeatable structures.' },
  { type: 'Podcasts', title: 'Independent builders', impact: 'Reinforced the value of shipping small, meaningful tools.' },
  { type: 'Documentaries', title: 'Space and music', impact: 'Connected technical curiosity with creative expression.' },
];
---

<BaseLayout title={site.title} description={site.description}>
  <MusicDecor client:load position="top-left" />
  <MusicDecor client:load position="bottom-right" />

  <Container class="home-shell">
    <Hero client:load />

    <MicrosoftExperience client:load />

    <DatawhaleStory />

    <section class="section-block">
      <Music />
    </section>

    <section id="projects" class="section-block">
      <div class="section-heading split-heading">
        <div>
          <p class="eyebrow">Projects</p>
        </div>
        <a class="section-link" href="/projects/">All projects →</a>
      </div>

      <div class="project-grid">
        {featuredProjects.map((project) => (
          <article class="project-card surface">
            <div class="project-meta">
              <span>{project.label}</span>
              <span>{project.type}</span>
            </div>
            <h3>{project.name}</h3>
            <p>{project.summary}</p>
            <ul>
              {project.tags.map((tag) => <li>{tag}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </section>

    <section class="section-block story-section" aria-labelledby="story-title">
      <div class="story-card surface">
        <p class="eyebrow">Personal philosophy</p>
        <h2 id="story-title">Story is the interface</h2>
        <p>
          Tools become memorable when they carry a story: why they exist, what tension they resolve, and what kind of future they point toward. This site is the place where I connect engineering practice with creative memory.
        </p>
      </div>
    </section>

    <section id="experience" class="section-block">
      <div>
        <p class="eyebrow">Works</p>
      </div>

      <div class="experience-list">
        {resume.work.map((item) => (
          <article class="experience-item surface">
            <div>
              <h3>{item.position}</h3>
              <p class="company">{item.company}</p>
              <p>{item.summary}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section-block">
      <div class="section-heading split-heading">
        <div>
          <p class="eyebrow">Favorites</p>
          <h2 class="favorites-title">Ideas that light the path</h2>
        </div>
        <a class="section-link" href="/favorites/">Open favorites →</a>
      </div>

      <div class="inspiration-grid">
        {inspirationPreview.map((item) => (
          <article class="inspiration-card surface">
            <span>{item.type}</span>
            <h3>{item.title}</h3>
            <p>{item.impact}</p>
          </article>
        ))}
      </div>
    </section>

    <FilmStrip speed={50} direction="left" imageHeight={220} />
  </Container>
</BaseLayout>

<script>
  import * as THREE from 'three';

  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  const initStarfield = () => {
    const canvas = document.querySelector<HTMLCanvasElement>('#webgl-starfield');
    if (!canvas) return;

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true, powerPreference: 'high-performance' });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.8));

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(62, window.innerWidth / window.innerHeight, 0.1, 1200);
    camera.position.z = 150;

    const starCount = 5000;
    const positions = new Float32Array(starCount * 3);
    const colors = new Float32Array(starCount * 3);
    const color = new THREE.Color();

    for (let i = 0; i < starCount; i += 1) {
      const radius = 120 + Math.random() * 560;
      const theta = Math.random() * Math.PI * 2;
      const phi = Math.acos(2 * Math.random() - 1);
      const i3 = i * 3;

      positions[i3] = radius * Math.sin(phi) * Math.cos(theta);
      positions[i3 + 1] = radius * Math.sin(phi) * Math.sin(theta);
      positions[i3 + 2] = radius * Math.cos(phi) - 190;

      color.setHSL(0.56 + Math.random() * 0.18, 0.42 + Math.random() * 0.3, 0.7 + Math.random() * 0.26);
      colors[i3] = color.r;
      colors[i3 + 1] = color.g;
      colors[i3 + 2] = color.b;
    }

    const geometry = new THREE.BufferGeometry();
    geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    geometry.setAttribute('color', new THREE.BufferAttribute(colors, 3));

    const material = new THREE.PointsMaterial({
      size: 1.18,
      sizeAttenuation: true,
      vertexColors: true,
      transparent: true,
      opacity: 0.86,
      depthWrite: false,
      blending: THREE.AdditiveBlending,
    });

    const stars = new THREE.Points(geometry, material);
    scene.add(stars);

    const resize = () => {
      renderer.setSize(window.innerWidth, window.innerHeight, false);
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
    };

    resize();
    window.addEventListener('resize', resize);

    let frame = 0;
    const animate = () => {
      frame = requestAnimationFrame(animate);
      if (!reducedMotion) {
        stars.rotation.y += 0.00042;
        stars.rotation.x += 0.0001;
        camera.position.x = Math.sin(performance.now() * 0.00008) * 8;
        camera.position.y = Math.cos(performance.now() * 0.00007) * 5;
        camera.lookAt(0, 0, -120);
      }
      renderer.render(scene, camera);
    };

    animate();

    window.addEventListener('pagehide', () => {
      cancelAnimationFrame(frame);
      window.removeEventListener('resize', resize);
      geometry.dispose();
      material.dispose();
      renderer.dispose();
    }, { once: true });
  };



  initStarfield();
</script>

<style>
  .home-shell {
    position: relative;
  }

  .eyebrow {
    margin-bottom: var(--space-4);
    /* 金色作为引导文字 - 钢琴铜金 */
    color: var(--color-gold, #c9a962);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .coordinate-strip {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-top: var(--space-8);
  }

  .coordinate-strip span,
  .project-card li {
    /* 浅灰边框 */
    border: 1px solid var(--color-border, rgba(229, 231, 235, 0.8));
    border-radius: 999px;
    padding: 0.72rem 0.92rem;
    /* 浅灰渐变背景 */
    background: var(--color-section-bg, #f0f2f5);
    /* 深灰文字 */
    color: var(--color-text-body, #4b5563);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    /* 顶部高光 */
    box-shadow: inset 1px 1px 0 rgba(255, 255, 255, 0.8);
  }

  .section-block {
    padding: var(--space-16) 0;
  }

  .split-heading {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(220px, 0.42fr);
    gap: var(--space-8);
    align-items: end;
    margin-bottom: var(--space-8);
  }

  .section-heading h2 {
    margin-bottom: 0;
  }

  .favorites-title {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-text-body, #4b5563);
    margin-top: var(--space-2);
  }

  .section-heading > p,
  .section-link {
    margin-bottom: 0;
    /* 中灰辅助文字 */
    color: var(--color-muted, #6b7280);
  }

  .section-link {
    font-family: var(--font-mono);
    font-size: 0.84rem;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .section-link:hover {
    color: var(--color-accent, #3b82f6);
  }

  .project-grid,
  .inspiration-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .experience-list {
    display: grid;
    gap: var(--space-4);
  }

  .project-card,
  .inspiration-card,
  .story-card,
  .experience-item {
    padding: var(--space-6);
    transition: transform 220ms ease, border-color 220ms ease, box-shadow 220ms ease;
  }

  .project-card {
    min-height: 360px;
  }

  .project-card:hover,
  .inspiration-card:hover,
  .experience-item:hover {
    transform: translateY(-6px);
    border-color: rgba(59, 130, 246, 0.3);
    box-shadow: 0 25px 80px rgba(59, 130, 246, 0.12), inset 1px 1px 0 rgba(255, 255, 255, 0.9);
  }

  .project-meta,
  .inspiration-card span,
  .experience-item > span {
    display: flex;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-8);
    /* 蓝色标签文字 */
    color: var(--color-accent, #3b82f6);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .project-card h3 {
    margin-bottom: var(--space-4);
    font-size: clamp(1.45rem, 3vw, 2.4rem);
  }

  .project-card ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin: var(--space-6) 0 0;
    padding: 0;
    list-style: none;
  }

  .story-section {
    display: grid;
  }

  .story-card {
    max-width: 900px;
    justify-self: center;
    text-align: center;
  }

  .story-card h2 {
    margin-bottom: var(--space-6);
  }

  .story-card p:last-child {
    max-width: 720px;
    margin: 0 auto;
    font-size: clamp(1.05rem, 2vw, 1.2rem);
  }

  .experience-item {
    display: block;
  }

  .experience-item h3 {
    margin-bottom: var(--space-2);
  }

  .company {
    margin-bottom: var(--space-3);
    color: var(--color-muted, #6b7280);
    font-family: var(--font-mono);
    font-size: 0.82rem;
  }

  .inspiration-card {
    min-height: 240px;
    transition: transform 220ms ease, border-color 220ms ease, box-shadow 220ms ease;
  }

  .inspiration-card h3 {
    margin-bottom: var(--space-4);
  }

  /* Piano Music Section Styles */
  .piano-section {
    position: relative;
  }

  .piano-container {
    overflow: hidden;
  }

  .piano-header {
    padding: var(--space-6) var(--space-6) 0;
    margin-bottom: var(--space-6);
  }

  .piano-header h2 {
    margin-bottom: var(--space-2);
  }

  .piano-header p {
    max-width: 600px;
    font-size: 1.05rem;
  }

  .piano-content {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: var(--space-6);
    padding: 0 var(--space-6) var(--space-6);
  }

  .piano-image-wrapper {
    position: relative;
    border-radius: var(--radius-lg, 16px);
    overflow: hidden;
    background: var(--color-section-bg, #f0f2f5);
    min-height: 320px;
  }

  .piano-image {
    width: 100%;
    height: 100%;
    min-height: 320px;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .piano-image-wrapper:hover .piano-image {
    transform: scale(1.03);
  }

  .piano-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    color: var(--color-muted, #6b7280);
    background: linear-gradient(135deg, rgba(59, 130, 246, 0.08), rgba(16, 185, 129, 0.05));
  }

  .piano-placeholder svg {
    width: 64px;
    height: 64px;
    opacity: 0.6;
  }

  .piano-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .music-card {
    padding: var(--space-5);
    border-radius: var(--radius-md, 10px);
    background: var(--color-bg-soft, #fafafa);
    border: 1px solid var(--color-border-soft, rgba(229, 231, 235, 0.6));
    transition: all 0.3s ease;
  }

  .music-card:hover {
    background: rgba(59, 130, 246, 0.04);
    border-color: rgba(59, 130, 246, 0.2);
    transform: translateX(4px);
  }

  .music-card h3 {
    margin-bottom: var(--space-2);
    font-size: 1.15rem;
  }

  .music-card p {
    margin-bottom: 0;
    font-size: 0.95rem;
    line-height: 1.6;
  }

  @media (max-width: 960px) {
    .split-heading,
    .skill-row,
    .project-grid,
    .inspiration-grid,
    .experience-item {
      grid-template-columns: 1fr;
    }

    .piano-content {
      grid-template-columns: 1fr;
    }

    .piano-image-wrapper {
      order: -1;
    }
  }
</style>
