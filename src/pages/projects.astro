---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Container from '../components/ui/Container.astro';
import ProjectCard from '../components/shared/ProjectCard.astro';

const projects = (await getCollection('projects'))
  .sort((a, b) => a.data.order - b.data.order);

const projectEntries = await Promise.all(
  projects.map(async (project) => ({
    project,
    Content: (await render(project)).Content,
  }))
);
---

<BaseLayout title="Projects" description="Selected projects, experiments, and case studies.">
  <Container>
    <section class="page-hero">
      <p class="kicker">Projects</p>
    </section>

    <div class="project-list">
      {projectEntries.map(({ project, Content }) => (
        <section id={project.id} class="project-entry">
          <ProjectCard project={project} />
          <article class="prose project-body">
            <Content />
          </article>
        </section>
      ))}
    </div>
  </Container>
</BaseLayout>

<style>
  .page-hero {
    max-width: 860px;
    padding: var(--space-16) 0 var(--space-12);
  }

  .project-list {
    display: grid;
    gap: var(--space-12);
  }

  .project-entry {
    display: grid;
    gap: var(--space-6);
  }

  .project-body {
    padding-bottom: var(--space-8);
    border-bottom: 1px solid var(--color-border);
  }

  @media (min-width: 900px) {
    .project-entry {
      grid-template-columns: 380px 1fr;
      align-items: start;
    }
  }
</style>
