---
export interface StoryPhase {
  title: string;
  description: string;
  year?: string;
}

export interface GalleryItem {
  image: string;
  title: string;
  description: string;
}

// ==================== DATA CONFIGURATION - Edit here to customize ====================
const storyPhases: StoryPhase[] = [
  {
    title: 'First Encounter',
    description: 'Joined the open-source learning community, beginning my journey with Datawhale.',
    year: '2022',
  },
  {
    title: 'Ongoing Contribution',
    description: 'Served as a teaching assistant and operations coordinator, promoting open-source culture as a community ambassador.',
    year: '2023 - 2025',
  },
  {
    title: 'Official Member',
    description: 'Became an official community member, authoring technical tutorials and contributing to the open-source ecosystem.',
    year: '2026',
  },
];

const galleryItems: GalleryItem[] = [
  {
    image: '/images/course.jpg',
    title: 'Open Learning',
    description: 'Collaborative learning and knowledge sharing',
  },
  {
    image: '/images/2050.jpg',
    title: 'Community Events',
    description: 'Connecting developers across China',
  },
];
// =========================================================================
---

<section id="datawhale-story" class="datawhale-section" aria-labelledby="datawhale-title">
  <div class="datawhale-container">
    {/* Left - Story Timeline */}
    <div class="story-left">
      <a href="https://github.com/datawhalechina" target="_blank" rel="noopener noreferrer" class="title-link">
        <h2 id="datawhale-title" class="section-title">Datawhale</h2>
      </a>
      <p class="section-subtitle">Growing with the open-source community</p>

      <div class="timeline">
        {storyPhases.map((phase, index) => (
          <div class="timeline-item animate-on-scroll" data-index={index}>
            <div class="timeline-dot">
              <div class="pulse-ring"></div>
            </div>
            <div class="timeline-content">
              {phase.year && <span class="timeline-year">{phase.year}</span>}
              <h3 class="timeline-title">{phase.title}</h3>
              <p class="timeline-desc">{phase.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    {/* Right - Image Cards */}
    <div class="gallery-right">
      <div class="gallery-grid">
        {galleryItems.map((item, index) => (
          <div class="gallery-card animate-on-scroll" data-index={index}>
            <div class="card-image-wrapper">
              <img
                src={item.image}
                alt={item.title}
                class="card-image"
                loading="lazy"
              />
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const observerOptions = {
      root: null,
      rootMargin: '0px',
      threshold: 0.15,
    };

    const animateOnScroll = (entries: IntersectionObserverEntry[]) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const element = entry.target as HTMLElement;
          const index = parseInt(element.dataset.index || '0');
          setTimeout(() => {
            element.classList.add('animated');
          }, index * 120);
        }
      });
    };

    const observer = new IntersectionObserver(animateOnScroll, observerOptions);
    document.querySelectorAll('.animate-on-scroll').forEach((el) => observer.observe(el));

  });
</script>

<style>
  /* Blue color palette */
  :root {
    --dw-blue-primary: #2563eb;
    --dw-blue-dark: #1e40af;
    --dw-blue-light: #60a5fa;
    --dw-blue-bg: #eff6ff;
    --dw-blue-gradient: linear-gradient(135deg, rgba(37, 99, 235, 0.9), rgba(30, 64, 175, 0.95));
  }

  .datawhale-section {
    width: 100%;
    padding: 4rem 0;
    font-family: var(--font-sans), Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  }

  .datawhale-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 0.4fr 0.6fr;
    gap: 3rem;
    align-items: start;
  }

  /* Left Section */
  .story-left {
    position: sticky;
    top: 2rem;
  }

  .title-link {
    text-decoration: none;
    display: inline-block;
    transition: transform 0.2s ease;
  }

  .title-link:hover {
    transform: translateX(4px);
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: var(--dw-blue-primary);
    margin: 0 0 0.5rem 0;
    letter-spacing: -0.03em;
    transition: color 0.2s ease;
  }

  .title-link:hover .section-title {
    color: var(--dw-blue-dark);
  }

  .section-subtitle {
    font-size: 1.1rem;
    color: var(--color-muted, #6b7280);
    margin: 0 0 2.5rem 0;
    font-weight: 400;
  }

  /* Timeline */
  .timeline {
    position: relative;
    padding-left: 2rem;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 0.35rem;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg, var(--dw-blue-primary), var(--dw-blue-light));
  }

  .timeline-item {
    position: relative;
    padding-bottom: 2rem;
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .timeline-item.animated {
    opacity: 1;
    transform: translateY(0);
  }

  .timeline-dot {
    position: absolute;
    left: -2rem;
    top: 0.25rem;
    width: 12px;
    height: 12px;
    background: var(--dw-blue-primary);
    border-radius: 50%;
    border: 3px solid #ffffff;
    box-shadow: 0 0 0 2px var(--dw-blue-primary);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pulse-ring {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 2px solid var(--dw-blue-light);
    animation: pulse 2s ease-out infinite;
  }

  @keyframes pulse {
    0% {
      transform: translate(-50%, -50%) scale(1);
      opacity: 1;
    }
    100% {
      transform: translate(-50%, -50%) scale(2);
      opacity: 0;
    }
  }

  .timeline-year {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--dw-blue-primary);
    background: var(--dw-blue-bg);
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    margin-bottom: 0.5rem;
    font-family: var(--font-mono);
  }

  .timeline-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-text-heading, #1f2937);
    margin: 0 0 0.375rem 0;
  }

  .timeline-desc {
    font-size: 0.95rem;
    color: var(--color-text-body, #4b5563);
    margin: 0;
    line-height: 1.6;
  }

  /* Right Gallery Section */
  .gallery-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    /* Align image top with first timeline dot center */
    margin-top: 5.5rem;
  }

  .gallery-card {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .gallery-card.animated {
    opacity: 1;
    transform: translateY(0);
  }

  .card-image-wrapper {
    border-radius: 16px;
    overflow: hidden;
    background: var(--dw-blue-bg);
    box-shadow: 0 4px 20px rgba(37, 99, 235, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .gallery-card:hover .card-image-wrapper {
    transform: translateY(-6px);
    box-shadow: 0 12px 40px rgba(37, 99, 235, 0.2);
  }

  .card-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: contain;
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .datawhale-container {
      grid-template-columns: 0.35fr 0.65fr;
      gap: 2rem;
    }
  }

  @media (max-width: 768px) {
    .datawhale-section {
      padding: 2.5rem 0;
    }

    .datawhale-container {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .story-left {
      position: static;
    }

    .gallery-grid {
      margin-top: 0;
    }

    .card-image-wrapper {
      height: 160px;
    }
  }

  @media (max-width: 480px) {
    .datawhale-container {
      padding: 0 1rem;
    }

    .gallery-grid {
      grid-template-columns: 1fr;
    }

    .card-image-wrapper {
      height: 180px;
    }

    .timeline {
      padding-left: 1.5rem;
    }

    .timeline-dot {
      left: -1.5rem;
    }

    .timeline::before {
      left: 0.35rem;
    }
  }
</style>
