---
const { as: Tag = 'div', class: className = '' } = Astro.props;
---

<Tag class:list={['container', className]}>
  <slot />
</Tag>

<style>
  .container {
    width: min(calc(100% - 2rem), var(--container));
    margin-inline: auto;
  }

  @media (min-width: 768px) {
    .container {
      width: min(calc(100% - 4rem), var(--container));
    }
  }
</style>
