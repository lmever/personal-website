---
import site from '../../data/site.json';
---

<header class="site-header">
  <!-- Left Navigation Menu -->
  <nav class="nav-left" aria-label="Main navigation">
    <!-- Logo / Site Name -->
    <a href="/#home" class="nav-brand">
      lmever
    </a>

    <!-- Favorites with Icon -->
    <a href="/favorites" class="nav-link nav-favorites">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="favorites-icon">
        <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
      </svg>
      <span>Favorites</span>
    </a>

    <!-- Other Navigation Links -->
    <a href="/#experience" class="nav-link">Experience</a>
    <a href="/#code" class="nav-link">Code</a>
    <a href="/#music" class="nav-link">Music</a>
    <a href="/#books" class="nav-link">Books</a>
