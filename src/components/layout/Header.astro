  <!-- Mobile Menu Toggle (Visible only on small screens) -->
  <button class="mobile-toggle" aria-label="Toggle menu">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="3" y1="12" x2="21" y2="12"/>
      <line x1="3" y1="6" x2="21" y2="6"/>
      <line x1="3" y1="18" x2="21" y2="18"/>
    </svg>
  </button>
</header>

<style>
  .site-header {
    /* Fixed at top, full width */
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    width: 100%;
    z-index: 20;

    /* Frosted glass effect */
    background: linear-gradient(to bottom, rgba(249, 250, 251, 0.9), rgba(249, 250, 251, 0));
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);

    /* Top border - light gray */
    border-bottom: 1px solid rgba(209, 213, 219, 0.1);

    /* Padding: mobile px-4, larger screens px-16/32/44 */
    padding: 1rem 1rem;

    /* Flex layout: items spaced */
    display: flex;
    align-items: center;
    justify-content: space-between;

    /* Text color: slate-700 (#334155) */
    color: #4b5563;

    /* Smooth transition */
    transition: all 0.3s ease;
  }

  /* Left Navigation Menu */
  .nav-left {
    display: flex;
    align-items: center;
    gap: 3rem; /* gap-x-12 */
  }

  /* Brand / Logo */
  .nav-brand {
    display: none; /* Hidden by default, shown on large screens */
    font-family: 'Georgia', 'Times New Roman', serif; /* Fantasy-like font */
    font-size: 1.5rem; /* text-2xl */
    font-weight: 700;
    color: #1f2937; /* slate-800 for better contrast */
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-brand:hover {
    color: #3b82f6; /* blue-500 on hover */
  }

  /* Navigation Links */
  .nav-link {
    display: none; /* Hidden by default, shown on large screens */
    font-size: 1.125rem; /* text-lg */
    color: #4b5563; /* slate-700 */
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: #0f172a; /* slate-900 on hover */
  }

  /* Favorites link with icon */
  .nav-favorites {
    display: none; /* Hidden by default, shown on large screens */
    align-items: center;
    gap: 0.25rem; /* gap-x-1 */
  }

  .favorites-icon {
    transition: transform 0.2s ease;
  }

  .nav-favorites:hover .favorites-icon {
    transform: scale(1.1);
  }

  /* Right Social Media Icons */
  .nav-right {
    display: flex;
    align-items: center;
    gap: 1rem; /* gap-x-4 */
  }

  .social-link {
    font-size: 1.5rem; /* text-2xl */
    color: #4b5563; /* slate-700 */
    text-decoration: none;
    transition: all 0.2s ease;
    line-height: 0;
  }

  .social-link:hover {
    color: #3b82f6; /* blue-500 on hover */
    transform: translateY(-2px);
  }

  /* Mobile Menu Toggle Button */
  .mobile-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: #4b5563;
    cursor: pointer;
    padding: 0.5rem;
    border-radius: 0.5rem;
    transition: all 0.2s ease;
  }

  .mobile-toggle:hover {
    background: rgba(59, 130, 246, 0.1);
    color: #3b82f6;
  }

  /* ============================================
     Responsive Breakpoints
     ============================================ */

  /* Large screens (lg: 1024px+) */
  @media (min-width: 1024px) {
    .site-header {
      padding-left: 4rem; /* px-16 */
      padding-right: 4rem; /* px-16 */
    }

    .nav-brand {
      display: block; /* Show logo on large screens */
    }

    .nav-link,
    .nav-favorites {
      display: flex; /* Show navigation links on large screens */
    }

    .mobile-toggle {
      display: none; /* Hide mobile toggle on large screens */
    }
  }

  /* Extra large screens (xl: 1280px+) */
  @media (min-width: 1280px) {
    .site-header {
      padding-left: 8rem; /* px-32 */
      padding-right: 8rem; /* px-32 */
    }
  }

  /* 2X large screens (2xl: 1536px+) */
  @media (min-width: 1536px) {
    .site-header {
      padding-left: 11rem; /* px-44 */
      padding-right: 11rem; /* px-44 */
    }
  }

  /* Small mobile screens */
  @media (max-width: 640px) {
    .site-header {
      padding-top: 0.75rem;
      padding-bottom: 0.75rem;
    }

    .nav-left {
      gap: 0;
    }
  }
</style>
